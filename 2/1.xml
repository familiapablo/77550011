    }).catch(function(err) {
        console.error(err);
    });
})();

// ================================================================
// 8) FOKUS TAKIBI
// ================================================================
var canvas = document.getElementById("unity-canvas");
canvas.addEventListener("mousedown", function() { window.focus(); }, false);

var focusChangedOnHas = true;
var focusChangedOnNot = true;

function checkWindowFocused() {
    if (player != null && unityI != null) {
        var focused = document.hasFocus() || (document.activeElement !== null && document.visibilityState === "visible");
        if (focused) {
            focusChangedOnNot = false;
            if (!focusChangedOnHas) {
                focusChangedOnHas = true;
                unityI.SendMessage("YandexSDK", "AppFocus", "true");
            }
        } else {
            focusChangedOnHas = false;
            if (!focusChangedOnNot) {
                focusChangedOnNot = true;
                unityI.SendMessage("YandexSDK", "AppFocus", "false");
            }
        }
    }
}

document.addEventListener("visibilitychange", checkWindowFocused);
setInterval(checkWindowFocused, 1333);

// ================================================================
// 9) YSDK STUB FONKSIYONLARI
// Framework.js su fonksiyonlari cagirir:
//   _SDKInit -> sdkInit()
//   _UserInit -> userInit()
//   _GetData / _GetUserData -> getUserData()
//   _SetData -> setUserData()
//   _ShowFullscreenAd -> showFullscrenAd()
//   _ShowRewardedAd -> showRewardedAd()
//   _Purchase -> buy()
//   _InitPurchases -> initPayments()
//   _AuthenticateUser -> auth()
// ================================================================

function sdkInit() {
    console.log("[Stub] SDK initialized");
    sdk = ysdk;
    setTimeout(function() {
        if (unityI) unityI.SendMessage("YandexSDK", "SDK_Inited");
