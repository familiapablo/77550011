    });
}

function setUserData(_data) {
    try { localStorage.setItem("aniga2_save", _data); } catch(e) {}
    console.log("[Stub] Data saved");
}

function getUserData() {
    console.log("[Stub] Data getting");
    try {
        var saved = localStorage.getItem("aniga2_save");
        if (saved) {
            if (unityI) unityI.SendMessage("YandexSDK", "DataGetting", JSON.stringify({ data: saved }));
        } else {
            if (unityI) unityI.SendMessage("YandexSDK", "DataGetting", JSON.stringify({}));
        }
    } catch(e) {
        if (unityI) unityI.SendMessage("YandexSDK", "DataGetting", JSON.stringify({}));
    }
}

function showFullscrenAd() {
    console.log("[Stub] Fullscreen ad -> atlandi");
