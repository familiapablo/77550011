<script>
// ================================================================
// 1) NAVIGATOR.LANGUAGE OVERRIDE - "en" ZORLA
// Framework.js SystemInfo.language'i navigator.language'den alir
// Bu override framework yuklenmeden ONCE olmali
// ================================================================
